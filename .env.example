# Expat NL Mortgage RAG – example environment (copy to .env and fill in)
# No secrets in this file.

# ---------- Qdrant ----------
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=property_docs

# ---------- LLM & Embeddings ----------
LLM_PROVIDER=openai
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=
OPENROUTER_API_KEY=
LLM_CHOICE=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Optional: Ollama (local)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Optional: model lists for sidebar (comma-separated)
# LLM_MODELS_OPENAI=gpt-4o-mini,gpt-4o
# LLM_MODELS_OPENROUTER=openai/gpt-4o-mini
# OLLAMA_MODELS=llama3.2:3b,llama3.1:8b

# ---------- Web search (Phase 1) ----------
TAVILY_API_KEY=

# ---------- Observability (Phase 1 / 3) ----------
LANGFUSE_HOST=
LANGFUSE_URL=

# ---------- Phase 2 (optional) ----------
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=

# ---------- Ingestion ----------
MAX_SEARCH_RESULTS=10
CHUNK_SIZE=800
CHUNK_OVERLAP=150
VECTOR_DIMENSION=1536
